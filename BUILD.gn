    "test/vi_file_venc_sync_userptr_vo_file_test.c",
]

  include_dirs = [
    "include",
    "utils/include",
    "al/include",
    "mpi/include",
    "test/include",
  ]

  output_name = "vi_file_venc_sync_userptr_vo_file_test"

  cflags_c = cflags_c_common

  cflags_cc = cflags_cc_common

  deps = [
    ":libutils",
    ":libspacemit_mpp",
  ]

  external_deps = [
  ]

  install_enable = true
  install_images = [ system_base_dir ]
  part_name = "spacemit_products"
}

