  "-Wno-pointer-sign",
  "-Wno-unused-function",
  "-Wno-pointer-to-int-cast",
]

cflags_cc_common = [
  "-Wno-pointer-sign",
  "-Wno-unused-function",
  "-Wno-pointer-to-int-cast",
]

ohos_executable("vi_file_venc_sync_userptr_vo_file_test") {
